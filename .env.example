# ---------------------------------------------------------------------------
# Hao Stock — root environment example
# Copy this file to server/.env (backend) and client/.env (frontend).
# See server/.env.example and client/.env.example for the per-app versions.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (production / staging).
# Get it from https://console.neon.tech -> your project -> Connection Details.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/hao_stock?sslmode=require

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Frontend (Vite needs the VITE_ prefix)
VITE_API_URL=http://localhost:4000/api
