# ---------------------------------------------------------------------------
# Hao Stock — environment example
#
# Local dev: copy to server/.env (backend) and client/.env (frontend).
# Vercel deploy (all-in-one): set these in the Vercel project's
#   Settings -> Environment Variables (NOT committed).
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# DATABASE_URL = the POOLED connection (host contains "-pooler"). Used at
# runtime by the serverless API; Neon's pooler keeps connection count sane.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/hao_stock?sslmode=require

# DIRECT_URL = the NON-pooled connection (no "-pooler"). Used for migrations
# (prisma migrate deploy / seed).
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/hao_stock?sslmode=require

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=optional-separate-secret

# --- Server -----------------------------------------------------------------
NODE_ENV=production
# PORT is only used when running as a long-lived server (local / non-Vercel).
PORT=4000
# Optional: only needed if the API is on a DIFFERENT origin than the frontend.
# On the all-in-one Vercel deploy the frontend and API share an origin, so CORS
# is not triggered and this can be left as-is.
CLIENT_ORIGIN=http://localhost:5173

# --- Frontend (Vite, build-time, must be prefixed VITE_) --------------------
# On the all-in-one Vercel deploy, leave this as /api (same origin as the API).
# Only set a full URL if the API is hosted on a separate domain.
VITE_API_URL=/api
