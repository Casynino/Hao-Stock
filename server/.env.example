# ---------------------------------------------------------------------------
# Hao Stock — backend (server) environment
# Copy to server/.env and fill in the values.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Pooled connection used by the app at runtime. From Neon -> Connection Details
# (choose the "Pooled connection" string, it ends with -pooler).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/hao_stock?sslmode=require"

# Direct (non-pooled) connection used by Prisma Migrate for DDL. From Neon,
# the "Direct connection" string (no -pooler). On local Postgres this can equal
# DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/hao_stock?sslmode=require"

# --- Auth -------------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"
JWT_REFRESH_EXPIRES_IN="30d"
BCRYPT_SALT_ROUNDS="10"

# --- Server -----------------------------------------------------------------
PORT="4000"
NODE_ENV="development"
# Comma-separated list of allowed CORS origins (frontend URLs).
CLIENT_ORIGIN="http://localhost:5173"
API_RATE_LIMIT_WINDOW_MS="900000"
API_RATE_LIMIT_MAX="500"
LOG_LEVEL="info"

# --- Business defaults ------------------------------------------------------
# Currency code & locale used for formatting in reports/exports.
CURRENCY="TZS"
LOCALE="en-TZ"
# Default credit term (days) applied to credit sales when none is given.
DEFAULT_CREDIT_TERM_DAYS="30"
# Default sales window (days) used by the reorder engine to compute velocity.
REORDER_LOOKBACK_DAYS="30"

# --- Seed admin (created by prisma/seed.js) ---------------------------------
SEED_ADMIN_NAME="System Administrator"
SEED_ADMIN_EMAIL="admin@haostock.co.tz"
SEED_ADMIN_PASSWORD="Admin@12345"
